# Dev / docker-compose image.
# Unlike the lean production ./Dockerfile, this keeps the full dependency set
# so the Prisma CLI (migrations) and ts-node (seeding) are available at runtime.
FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY prisma ./prisma
RUN npx prisma generate

COPY . .

EXPOSE 3000
CMD ["sh", "/app/scripts/docker-entrypoint.sh"]
