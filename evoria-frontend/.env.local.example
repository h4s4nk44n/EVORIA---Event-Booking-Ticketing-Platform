# Copy this file to .env.local, then start the dev server:
#   cp .env.local.example .env.local
# These are safe local-dev defaults — no secrets to fill in.

# Base URL of the evoria-backend API (consumed in lib/api.ts).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Port the Next.js dev server runs on. Keep this at 3001: the backend
# runs on 3000 and only allows http://localhost:3001 as a CORS origin.
PORT=3001
